// Schema del database di Amon Barbershop.
// Documentazione: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// Una prenotazione fatta da un cliente.
/// L'orario è memorizzato come data locale (YYYY-MM-DD) + minuti dalla
/// mezzanotte, così il calcolo della disponibilità è pura aritmetica e
/// non dipende dal fuso orario del server.
model Appointment {
  id            String   @id @default(cuid())
  serviceId     String
  serviceName   String
  durationMin   Int
  priceCents    Int
  customerName  String
  customerPhone String
  customerEmail String?
  notes         String?
  date          String // YYYY-MM-DD (ora locale negozio)
  startMin      Int // minuti dalla mezzanotte
  endMin        Int
  status        String   @default("confirmed") // confirmed | cancelled
  createdAt     DateTime @default(now())

  @@index([date, status])
}

/// Un blocco di indisponibilità inserito dal barbiere (ferie, pausa, impegno).
model Block {
  id        String   @id @default(cuid())
  date      String // YYYY-MM-DD
  startMin  Int
  endMin    Int
  reason    String?
  createdAt DateTime @default(now())

  @@index([date])
}

/// Utente dell'app gestionale: il titolare e i collaboratori.
/// Ogni persona ha le proprie credenziali (account separati).
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String
  role         String   @default("staff") // owner | staff
  createdAt    DateTime @default(now())
}

/// Servizio offerto (gestito dal barbiere, mostrato e prenotabile sul sito).
model Service {
  id          String  @id @default(cuid())
  name        String
  description String?
  durationMin Int
  priceCents  Int
  active      Boolean @default(true)
  sort        Int     @default(0)
}

/// Un intervallo di apertura per un giorno della settimana (0=dom … 6=sab).
/// Più righe sullo stesso giorno = più fasce (es. mattina e pomeriggio).
model OpeningHour {
  id       String @id @default(cuid())
  weekday  Int
  startMin Int
  endMin   Int

  @@index([weekday])
}

/// Impostazioni generiche chiave/valore (dati negozio, passo slot, ecc.).
model Setting {
  key   String @id
  value String
}
